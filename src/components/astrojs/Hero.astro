---
interface Props {
  title: string;
  description: string;
}

const {title, description} = Astro.props;
---

<section class="relative isolate px-6 lg:px-8 min-h-[calc(100vh-5rem)] flex items-center justify-center">
  <div class="mx-auto max-w-4xl py-8">
    <div class="text-center">

      <div class="relative inline-block mb-6">
        <span class="text-sm sm:text-base uppercase tracking-[0.3em] text-accent-glow font-body font-semibold">
          Saikomic • Votación Oficial
        </span>
      </div>

      <h1 class="text-5xl sm:text-7xl lg:text-8xl font-normal leading-[1.1] tracking-wide text-white font-display">
        {title}
      </h1>

      <div class="mt-4 h-1 w-24 mx-auto rounded-full bg-accent/50"></div>

      <p class="mt-8 text-base sm:text-lg leading-relaxed text-text-muted font-body max-w-2xl mx-auto font-medium">
        {description}
      </p>

      <div class="mt-12 flex items-center justify-center gap-x-6">
        <a
          href="/encuesta-resultados"
          class="px-10 py-4 text-lg uppercase tracking-widest font-display
            border-2 border-accent text-accent
            rounded-lg transition-all duration-300
            hover:scale-105 hover:text-white hover:border-accent-glow hover:bg-accent/10
            shadow-lg shadow-accent/5 hover:shadow-accent/20"
        >
          Ver Resultados
        </a>
      </div>
    </div>
  </div>
</section>

---
interface Props {
	title: string
	description: string
}

const { title, description } = Astro.props
---

<section class="relative isolate flex min-h-[calc(100vh-9rem)] items-center justify-center overflow-hidden px-6 lg:px-8">
	<div class="mx-auto max-w-4xl py-8">
		<div class="text-center">
			<div class="relative mb-6 inline-block">
				<span
					class="text-accent-glow font-body animate-fade-in-up text-sm font-semibold tracking-[0.3em] uppercase sm:text-base"
					style="animation-delay: 0.1s"
				>
					Antagonista • Votación Oficial
				</span>
			</div>

			<h1
				class="font-display animate-fade-in-up text-4xl leading-[1.1] font-normal tracking-wide text-white sm:text-5xl lg:text-6xl"
				style="animation-delay: 0.25s"
			>
				{title}
			</h1>

			<div
				class="bg-accent/50 mx-auto mt-4 h-1 w-24 animate-scale-in rounded-full"
				style="animation-delay: 0.4s"
			></div>

			<p
				class="text-text-muted font-body mx-auto mt-8 max-w-2xl animate-fade-in-up text-base leading-relaxed font-medium sm:text-lg"
				style="animation-delay: 0.5s"
			>
				{description}
			</p>

			<div class="mt-12 flex items-center justify-center gap-x-6">
				<a
					href="/encuesta-resultados"
					class="font-display animate-glow-in border-accent text-accent hover:border-accent-glow hover:bg-accent/10 shadow-accent/5 hover:shadow-accent/20 rounded-lg border-2 px-10 py-4 text-lg tracking-widest uppercase shadow-lg transition-all duration-300 hover:scale-105 hover:text-white"
					style="animation-delay: 0.65s"
				>
					Ver Resultados
				</a>
			</div>
		</div>
	</div>
</section>

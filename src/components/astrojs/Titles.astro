---
import Image from 'astro/components/Image.astro';

interface Props {
  title: string;
  subtitle: string;
  info: string;
}

const {title, subtitle, info} = Astro.props;
---

<div class="mb-12 text-center">
  <div class="relative inline-block mb-4">
    <span class="text-xs uppercase tracking-[0.25em] text-accent-dim font-body font-semibold">
      Encuesta de Popularidad
    </span>
  </div>
  <h2 class="mb-4 text-4xl sm:text-5xl lg:text-6xl font-normal leading-[1.15] tracking-wide text-white font-display">
    {title}
  </h2>
  <div class="mx-auto h-0.5 w-16 rounded-full bg-accent/25 mb-6"></div>
  <p class="mb-2 text-lg sm:text-xl text-text-muted font-body font-medium tracking-wider leading-relaxed max-w-2xl mx-auto">
    {subtitle}
  </p>
  <div class="mx-auto flex justify-center">
    <Image src="/encuesta.webp" width={800} height={280} alt="info" class="h-32 sm:h-72 w-auto object-cover" />
  </div>
</div>

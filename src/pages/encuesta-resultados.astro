---
import Layout from '@layouts/Layout.astro'
import { surveyResults } from '@data/survey-results'
import Crown from '@icons/Crown.astro'
import Medal from '@icons/Medal.astro'

const maxPoints = surveyResults[0].points
const top3 = surveyResults.slice(0, 3)
const rest = surveyResults.slice(3)
---

<Layout title="Resultados | Encuesta de Popularidad Antagonista">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
		<div class="mb-16 text-center">
			<span class="text-accent-dim font-body text-xs font-semibold tracking-[0.25em] uppercase"
				>Resultados Finales</span
			>
			<h1
				class="font-display mt-3 text-4xl leading-[1.15] font-normal tracking-wide text-white sm:text-5xl lg:text-6xl"
			>
				Resultados de la Encuesta
			</h1>
			<div class="bg-accent/40 mx-auto mt-4 h-0.5 w-16 rounded-full"></div>
			<p class="text-text-muted font-body mt-4 text-lg font-medium">Gracias por participar</p>
			<div
				class="bg-surface/60 border-surface-light mt-6 inline-flex items-center gap-3 rounded-xl border px-5 py-2.5"
			>
				<span class="text-text-muted font-body text-sm tracking-wider">Total de Votantes</span>
				<span class="text-accent font-score text-2xl font-bold">804</span>
			</div>
		</div>

		<!-- Podium -->
		<div class="relative mb-16 flex flex-col items-end justify-center gap-4 md:flex-row md:gap-6 lg:gap-8">
			{/* 2nd place - left */}
			<div class="order-2 w-full md:order-1 md:mt-12 md:w-1/3">
				<div class="bg-surface/40 relative overflow-hidden rounded-2xl border-2 border-neutral-400/30">
					<div class="relative h-44 overflow-hidden sm:h-52">
						<img
							src={top3[1].image}
							alt={top3[1].name}
							class="h-full w-full object-cover grayscale-[20%]"
							loading="lazy"
						/>
						<div class="from-ink via-ink/40 absolute inset-0 bg-gradient-to-t to-transparent"></div>
						<div
							class="absolute top-3 left-3 flex h-10 w-10 items-center justify-center rounded-xl bg-neutral-400/20 text-neutral-400 shadow-lg backdrop-blur-sm"
						>
							<Medal class="h-5 w-5" />
						</div>
					</div>
					<div class="p-4 text-center">
						<span class="font-body text-xs font-semibold tracking-widest text-neutral-400 uppercase"
							>2do Lugar</span
						>
						<h3 class="font-display mt-1 text-xl text-white">{top3[1].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="font-score text-4xl leading-none text-neutral-400">{top3[1].points}</span>
							<span class="text-text-muted font-body text-xs uppercase">pts</span>
						</div>
						<div class="bg-surface-light mt-3 h-1.5 w-full overflow-hidden rounded-full">
							<div
								class="h-full rounded-full bg-neutral-400 transition-all duration-700"
								style={`width: ${(top3[1].points / maxPoints) * 100}%`}
							>
							</div>
						</div>
					</div>
				</div>
			</div>

			{/* 1st place - center, elevated */}
			<div class="z-10 order-1 w-full md:order-2 md:-mt-8 md:w-1/3">
				<div
					class="border-accent/60 bg-accent/5 relative overflow-hidden rounded-2xl border-2 shadow-xl shadow-red-600/15"
				>
					<div class="relative h-56 overflow-hidden sm:h-64">
						<img src={top3[0].image} alt={top3[0].name} class="h-full w-full object-cover" loading="lazy" />
						<div class="from-ink via-ink/30 absolute inset-0 bg-gradient-to-t to-transparent"></div>
						<div
							class="bg-accent absolute top-3 left-3 flex h-11 w-11 items-center justify-center rounded-xl text-white shadow-lg shadow-red-600/30"
						>
							<Crown class="h-6 w-6" />
						</div>
						<div
							class="bg-accent/90 font-score absolute top-3 right-3 rounded-lg px-2.5 py-1 text-xs tracking-wider text-white shadow-lg"
						>
							#1
						</div>
					</div>
					<div class="p-5 text-center">
						<span class="text-accent font-body text-xs font-semibold tracking-widest uppercase">Ganador</span>
						<h3 class="font-display mt-1 text-2xl text-white">{top3[0].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="font-score text-accent text-5xl leading-none">{top3[0].points}</span>
							<span class="text-text-muted font-body text-xs uppercase">pts</span>
						</div>
						<div class="bg-surface-light mt-3 h-2 w-full overflow-hidden rounded-full">
							<div
								class="bg-accent h-full rounded-full transition-all duration-700"
								style={`width: ${(top3[0].points / maxPoints) * 100}%`}
							>
							</div>
						</div>
					</div>
				</div>
			</div>

			{/* 3rd place - right */}
			<div class="order-3 w-full md:mt-20 md:w-1/3">
				<div class="bg-surface/40 relative overflow-hidden rounded-2xl border-2 border-amber-700/30">
					<div class="relative h-36 overflow-hidden sm:h-44">
						<img
							src={top3[2].image}
							alt={top3[2].name}
							class="h-full w-full object-cover grayscale-[30%]"
							loading="lazy"
						/>
						<div class="from-ink via-ink/40 absolute inset-0 bg-gradient-to-t to-transparent"></div>
						<div
							class="absolute top-3 left-3 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-700/20 text-amber-700 shadow-lg backdrop-blur-sm"
						>
							<Medal class="h-5 w-5" />
						</div>
					</div>
					<div class="p-4 text-center">
						<span class="font-body text-xs font-semibold tracking-widest text-amber-700 uppercase"
							>3er Lugar</span
						>
						<h3 class="font-display mt-1 text-xl text-white">{top3[2].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="font-score text-4xl leading-none text-amber-700">{top3[2].points}</span>
							<span class="text-text-muted font-body text-xs uppercase">pts</span>
						</div>
						<div class="bg-surface-light mt-3 h-1.5 w-full overflow-hidden rounded-full">
							<div
								class="h-full rounded-full bg-amber-700 transition-all duration-700"
								style={`width: ${(top3[2].points / maxPoints) * 100}%`}
							>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Remaining ranks -->
		<div class="space-y-2">
			{
				rest.map((character) => (
					<div class="border-surface-light bg-surface/50 flex items-center gap-4 rounded-xl border p-4 sm:p-5">
						<span class="font-score text-text-muted w-8 text-center text-sm tracking-wider">
							#{character.rank}
						</span>
						<div class="border-surface-light h-14 w-14 flex-shrink-0 overflow-hidden rounded-lg border">
							<img
								src={character.image}
								alt={character.name}
								class="h-full w-full object-cover grayscale-[30%]"
								loading="lazy"
							/>
						</div>
						<div class="min-w-0 flex-grow">
							<h4 class="font-display truncate text-sm text-white sm:text-base">{character.name}</h4>
							<div class="bg-surface-light mt-1.5 h-1 w-full overflow-hidden rounded-full">
								<div
									class="bg-accent/40 h-full rounded-full"
									style={`width: ${(character.points / maxPoints) * 100}%`}
								/>
							</div>
						</div>
						<div class="flex-shrink-0 text-right">
							<span class="font-score text-accent text-2xl leading-none">{character.points}</span>
							<span class="text-text-muted font-body block text-xs tracking-wider uppercase">pts</span>
						</div>
					</div>
				))
			}
		</div>
	</div>
</Layout>

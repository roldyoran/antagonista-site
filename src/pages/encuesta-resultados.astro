---
import Layout from '@layouts/Layout.astro'
import { surveyResults } from '@data/survey-results'
import Crown from '@icons/Crown.astro'
import Medal from '@icons/Medal.astro'

const maxPoints = surveyResults[0].points
const top3 = surveyResults.slice(0, 3)
const rest = surveyResults.slice(3)
---

<Layout title="Resultados | Encuesta de Popularidad Antagonista">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">

		<div class="text-center mb-16">
			<span class="text-xs uppercase tracking-[0.25em] text-accent-dim font-body font-semibold">Resultados Finales</span>
			<h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-normal leading-[1.15] tracking-wide text-white font-display">
				Resultados de la Encuesta
			</h1>
			<div class="mx-auto mt-4 h-0.5 w-16 rounded-full bg-accent/40"></div>
			<p class="mt-4 text-lg text-text-muted font-body font-medium">
				Gracias por participar
			</p>
			<div class="mt-6 inline-flex items-center gap-3 px-5 py-2.5 rounded-xl bg-surface/60 border border-surface-light">
				<span class="text-text-muted font-body text-sm tracking-wider">Total de Votantes</span>
				<span class="text-2xl font-bold text-accent font-score">804</span>
			</div>
		</div>

		<!-- Podium -->
		<div class="relative flex flex-col md:flex-row items-end justify-center gap-4 mb-16 md:gap-6 lg:gap-8">
			{/* 2nd place - left */}
			<div class="w-full md:w-1/3 md:mt-12 order-2 md:order-1">
			<div class="relative rounded-2xl border-2 border-neutral-400/30 bg-surface/40 overflow-hidden">
				<div class="relative h-44 sm:h-52 overflow-hidden">
					<img
						src={top3[1].image}
						alt={top3[1].name}
						class="w-full h-full object-cover grayscale-[20%]"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent"></div>
						<div class="absolute top-3 left-3 flex items-center justify-center w-10 h-10 rounded-xl bg-neutral-400/20 text-neutral-400 shadow-lg backdrop-blur-sm">
							<Medal class="w-5 h-5" />
						</div>
					</div>
					<div class="p-4 text-center">
						<span class="text-xs uppercase tracking-widest text-neutral-400 font-body font-semibold">2do Lugar</span>
						<h3 class="mt-1 text-xl font-display text-white">{top3[1].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="text-4xl font-score text-neutral-400 leading-none">{top3[1].points}</span>
							<span class="text-xs text-text-muted font-body uppercase">pts</span>
						</div>
						<div class="mt-3 h-1.5 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class="h-full rounded-full bg-neutral-400 transition-all duration-700"
								style={`width: ${(top3[1].points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
				</div>
			</div>

			{/* 1st place - center, elevated */}
			<div class="w-full md:w-1/3 md:-mt-8 order-1 md:order-2 z-10">
			<div class="relative rounded-2xl border-2 border-accent/60 bg-accent/5 overflow-hidden shadow-xl shadow-red-600/15">
				<div class="relative h-56 sm:h-64 overflow-hidden">
					<img
						src={top3[0].image}
						alt={top3[0].name}
						class="w-full h-full object-cover"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/30 to-transparent"></div>
						<div class="absolute top-3 left-3 flex items-center justify-center w-11 h-11 rounded-xl bg-accent text-white shadow-lg shadow-red-600/30">
							<Crown class="w-6 h-6" />
						</div>
						<div class="absolute top-3 right-3 px-2.5 py-1 rounded-lg bg-accent/90 text-white text-xs font-score tracking-wider shadow-lg">
							#1
						</div>
					</div>
					<div class="p-5 text-center">
						<span class="text-xs uppercase tracking-widest text-accent font-body font-semibold">Ganador</span>
						<h3 class="mt-1 text-2xl font-display text-white">{top3[0].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="text-5xl font-score text-accent leading-none">{top3[0].points}</span>
							<span class="text-xs text-text-muted font-body uppercase">pts</span>
						</div>
						<div class="mt-3 h-2 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class="h-full rounded-full bg-accent transition-all duration-700"
								style={`width: ${(top3[0].points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
				</div>
			</div>

			{/* 3rd place - right */}
			<div class="w-full md:w-1/3 md:mt-20 order-3">
			<div class="relative rounded-2xl border-2 border-amber-700/30 bg-surface/40 overflow-hidden">
				<div class="relative h-36 sm:h-44 overflow-hidden">
					<img
						src={top3[2].image}
						alt={top3[2].name}
						class="w-full h-full object-cover grayscale-[30%]"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent"></div>
						<div class="absolute top-3 left-3 flex items-center justify-center w-10 h-10 rounded-xl bg-amber-700/20 text-amber-700 shadow-lg backdrop-blur-sm">
							<Medal class="w-5 h-5" />
						</div>
					</div>
					<div class="p-4 text-center">
						<span class="text-xs uppercase tracking-widest text-amber-700 font-body font-semibold">3er Lugar</span>
						<h3 class="mt-1 text-xl font-display text-white">{top3[2].name}</h3>
						<div class="mt-2 flex items-baseline justify-center gap-1.5">
							<span class="text-4xl font-score text-amber-700 leading-none">{top3[2].points}</span>
							<span class="text-xs text-text-muted font-body uppercase">pts</span>
						</div>
						<div class="mt-3 h-1.5 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class="h-full rounded-full bg-amber-700 transition-all duration-700"
								style={`width: ${(top3[2].points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Remaining ranks -->
		<div class="space-y-2">
			{rest.map((character) => (
				<div class="flex items-center gap-4 p-4 sm:p-5 rounded-xl border border-surface-light bg-surface/50">
					<span class="w-8 text-center text-sm font-score text-text-muted tracking-wider">
						#{character.rank}
					</span>
					<div class="w-14 h-14 rounded-lg overflow-hidden border border-surface-light flex-shrink-0">
						<img
							src={character.image}
							alt={character.name}
							class="w-full h-full object-cover grayscale-[30%]"
							loading="lazy"
						/>
					</div>
					<div class="flex-grow min-w-0">
						<h4 class="text-sm sm:text-base font-display text-white truncate">{character.name}</h4>
						<div class="mt-1.5 h-1 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class="h-full rounded-full bg-accent/40"
								style={`width: ${(character.points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
					<div class="text-right flex-shrink-0">
						<span class="text-2xl font-score text-accent leading-none">{character.points}</span>
						<span class="text-xs text-text-muted block font-body uppercase tracking-wider">pts</span>
					</div>
				</div>
			))}
		</div>


	</div>
</Layout>

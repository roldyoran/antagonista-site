---
import Layout from '@layouts/Layout.astro'
import { surveyResults } from '@data/survey-results'

const maxPoints = surveyResults[0].points
const top3 = surveyResults.slice(0, 3)
const rest = surveyResults.slice(3)
---

<Layout title="Resultados | Encuesta de Popularidad Antagonista">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">

		<div class="text-center mb-12">
			<span class="text-xs uppercase tracking-[0.25em] text-accent-dim font-body font-semibold">Resultados Finales</span>
			<h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-normal leading-[1.15] tracking-wide text-white font-display">
				Resultados de la Encuesta
			</h1>
			<div class="mx-auto mt-4 h-0.5 w-16 rounded-full bg-accent/40"></div>
			<p class="mt-4 text-lg text-text-muted font-body font-medium">
				¡Gracias por participar!
			</p>
			<div class="mt-6 inline-flex items-center gap-3 px-5 py-2.5 rounded-xl bg-surface/60 border border-surface-light">
				<span class="text-text-muted font-body text-sm tracking-wider">Total de Votantes</span>
				<span class="text-2xl font-bold text-accent font-display">804</span>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
			{top3.map((character, i) => (
				<div class:list={[
					'relative rounded-2xl border-2 overflow-hidden transition-all duration-300 hover:scale-[1.02]',
					i === 0 ? 'md:order-2 border-accent/50 bg-accent/5 shadow-lg shadow-red-600/10' :
					i === 1 ? 'md:order-1 border-surface-light bg-surface/40' :
					'border-surface-light bg-surface/40'
				]}>
					<div class="relative h-48 sm:h-56 overflow-hidden">
						<img
							src={character.image}
							alt={character.name}
							class="w-full h-full object-cover"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/30 to-transparent"></div>
						<div class:list={[
							'absolute top-3 left-3 flex items-center justify-center w-10 h-10 rounded-xl font-display text-lg shadow-lg',
							i === 0 ? 'bg-accent text-white' :
							i === 1 ? 'bg-neutral-400 text-neutral-900' :
							'bg-amber-700 text-white'
						]}>
							{i === 0 ? '👑' : i === 1 ? '🥈' : '🥉'}
						</div>
					</div>
					<div class="p-4 text-center">
						<h3 class="text-xl font-display text-white mb-1">{character.name}</h3>
						<div class="flex items-center justify-center gap-2">
							<span class="text-2xl font-bold text-accent font-display">{character.points}</span>
							<span class="text-sm text-text-muted">pts</span>
						</div>
						<div class="mt-3 h-1.5 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class:list={[
									'h-full rounded-full transition-all duration-700',
									i === 0 ? 'bg-accent' :
									i === 1 ? 'bg-neutral-400' :
									'bg-amber-700'
								]}
								style={`width: ${(character.points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
				</div>
			))}
		</div>

		<div class="space-y-3">
			{rest.map((character) => (
				<div class="flex items-center gap-4 p-3 sm:p-4 rounded-xl border border-surface-light bg-surface/30 hover:bg-surface/50 hover:border-accent/20 transition-all duration-200 group">
					<span class="w-8 text-center text-lg font-display text-text-muted group-hover:text-accent transition-colors">
						#{character.rank}
					</span>
					<div class="w-12 h-12 rounded-lg overflow-hidden border border-surface-light flex-shrink-0">
						<img
							src={character.image}
							alt={character.name}
							class="w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-300"
							loading="lazy"
						/>
					</div>
					<div class="flex-grow min-w-0">
						<h4 class="text-sm sm:text-base font-display text-white truncate">{character.name}</h4>
						<div class="mt-1.5 h-1 w-full rounded-full bg-surface-light overflow-hidden">
							<div
								class="h-full rounded-full bg-accent/40 group-hover:bg-accent transition-all duration-500"
								style={`width: ${(character.points / maxPoints) * 100}%`}
							/>
						</div>
					</div>
					<div class="text-right flex-shrink-0">
						<span class="text-lg font-bold text-accent font-display">{character.points}</span>
						<span class="text-xs text-text-muted block">pts</span>
					</div>
				</div>
			))}
		</div>

		<div class="mt-12 text-center">
			<a
				href="/personajes"
				class="inline-block px-8 py-3 text-base uppercase tracking-wider font-display
					border-2 border-accent text-accent rounded-lg transition-all duration-300
					hover:bg-accent/10 hover:text-accent-glow"
			>
				Votar Ahora
			</a>
		</div>
	</div>
</Layout>
